{"remainingRequest":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/thread-loader/dist/cjs.js!/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/babel-loader/lib/index.js!/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/src/views/curso/Tema3.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/src/views/curso/Tema3.vue","mtime":1745443259647},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/babel.config.js","mtime":1745443259556},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/thread-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/runner/work/U2_Comunicaci-n-y-trabajo-en-equipo/U2_Comunicaci-n-y-trabajo-en-equipo/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Tema3.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgLA,OAAA,SAAA,MAAA,sCAAA;AACA,eAAA;AACA,EAAA,IAAA,EAAA,OADA;AAEA,EAAA,UAAA,EAAA;AACA,IAAA,SAAA,EAAA;AADA,GAFA;AAKA,EAAA,IAAA,EAAA;AAAA,WAAA;AACA,MAAA,YAAA,EAAA;AACA,QAAA,IAAA,EAAA,+BADA;AAEA,QAAA,MAAA,EAAA,gBAFA;AAGA,QAAA,YAAA,EACA,8EAJA;AAKA,QAAA,gBAAA,EAAA,IALA;AAMA,QAAA,SAAA,EAAA,CACA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,iEAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,wBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WADA,EAEA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,gCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAFA,EAOA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,kCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAPA,EAYA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,iCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,CALA;AAuBA,UAAA,gBAAA,EAAA,sCAvBA;AAwBA,UAAA,kBAAA,EACA;AAzBA,SADA,EA4BA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EAAA,4DAFA;AAGA,UAAA,iBAAA,EAAA,IAHA;AAIA,UAAA,QAAA,EAAA,CACA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,uBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WADA,EAEA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,gCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAFA,EAOA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,sBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAPA,EAQA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,+BAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WARA,CAJA;AAkBA,UAAA,gBAAA,EAAA,sCAlBA;AAmBA,UAAA,kBAAA,EACA;AApBA,SA5BA,CANA;AAyDA,QAAA,sBAAA,EAAA,uCAzDA;AA0DA,QAAA,uBAAA,EACA;AA3DA;AADA,KAAA;AAAA,GALA;AAoEA,EAAA,OApEA,qBAoEA;AAAA;;AACA,SAAA,SAAA,CAAA,YAAA;AACA,MAAA,KAAA,CAAA,WAAA;AACA,KAFA;AAGA;AAxEA,CAAA","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(:subTitulo=\"'3. Técnicas y habilidades personales y sociales necesarias para el trabajo en equipo'\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5.overflow-hidden\n  \n      .row.mb-4\n        .col-12.col-xl-8\n          .d-flex.align-items-start.bg-amarillo.p-4(data-aos='fade-up').d-flex.align-items-center.flex-column.flex-md-row.mb-4\n            img.me-3(style='width: 90px' src='@/assets/curso/unidad/img-54.svg', alt='Texto descriptivo de la imagen')\n            .my-auto\n              p.pe-xl-3.mb-0 En el ámbito empresarial es necesario que los trabajadores cuenten, además de los conocimientos técnicos requeridos, con una serie de habilidades personales y sociales que les permitan desenvolverse con éxito en el desempeño de sus funciones y que les permitan mantener relaciones efectivas con los compañeros, superiores, subordinados, clientes, proveedores (Cruz, 2014).  \n          span Por lo tanto en el contexto laboral actual, caracterizado por su dinamismo y la constante evolución de las condiciones de trabajo, el trabajo en equipo ha emergido como un componente esencial para el éxito organizacional. La eficacia de un equipo no solo se basa en la suma de talentos individuales, sino en la calidad de las interacciones y la sinergia creada entre sus miembros. En este sentido, las habilidades personales y sociales, juegan un papel fundamental en la construcción de equipos efectivos. Esta redacción se centrará en la importancia de estas habilidades, explorando su impacto en la comunicación, la empatía, la gestión de la diversidad, la resiliencia, la resolución de conflictos y la autoeficacia, entre otros aspectos.\n        .col-4.d-none.d-xl-block\n          img(src='@/assets/curso/unidad/img-55.png', alt='Texto que describa la imagen')\n\n      #t_3_1.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.1\n          h2 La comunicación efectiva como pilar del trabajo en equipo\n\n      .row.mb-4\n        .col-3.d-none.d-xl-block\n          img(src='@/assets/curso/unidad/img-56.png', alt='Texto que describa la imagen')\n        .col-12.col-xl-9\n          p.mb-4 Como ya se ha expuesto, la comunicación efectiva es uno de los pilares fundamentales del trabajo en equipo. No se trata solo de transmitir información, sino de establecer un diálogo abierto y constructivo, que permita a todos los miembros del equipo expresar sus ideas y preocupaciones. La capacidad de escuchar activamente, es tan crucial como la habilidad de hablar con claridad. Un equipo que practica la comunicación bidireccional, crea un ambiente de confianza donde cada miembro se siente valorado y comprendido.\n          .row.bg-verde.p-4.py-xl-0.mb-4(data-aos=\"fade-up\")\n            .col-4.d-none.d-xl-block\n              img(src='@/assets/curso/unidad/img-57.png', alt='Texto que describa la imagen')\n            .col-12.col-xl-8.d-flex\n              p.my-auto La falta de comunicación efectiva puede llevar a malentendidos, frustraciones y, en última instancia, al fracaso del equipo. Por lo tanto, es esencial fomentar habilidades como la asertividad, la claridad en la expresión y la escucha activa.\n          span Las herramientas de comunicación moderna, como las plataformas digitales, también juegan un papel clave en la facilitación de la interacción entre los miembros del equipo, permitiendo una comunicación fluida y accesible.\n\n      #t_3_2.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.2\n          h2 La empatía y su importancia en el entorno colaborativo\n\n      .row.mb-4\n        p.mb-4 En cuanto a la <b>empatía:</b>\n        .col-12.col-xl-7\n          LineaTiempoD.color-secundario\n            p(numero='1' titulo='Paso 1') La empatía es otra habilidad crítica en el trabajo en equipo. La capacidad de comprender y compartir los sentimientos de los demás, contribuye a la cohesión grupal y a la creación de un entorno de apoyo. Cuando los miembros de un equipo se muestran empáticos, es más probable que se ayuden mutuamente, lo que fortalece las relaciones y mejora la moral. \n            p(numero='2' titulo='Paso 2') La empatía permite a los equipos manejar mejor los conflictos. Al comprender las perspectivas de los demás, los miembros pueden abordar los desacuerdos de manera constructiva, buscando soluciones que beneficien a todos. Fomentar un entorno empático no solo mejora el clima laboral, sino que también promueve la innovación y la creatividad, dado que los miembros se sienten seguros para compartir ideas y opiniones. \n            p(numero='3' titulo='Paso 3') La empatía, cuando se habla de trabajo en equipo, es esencial, puesto que permitirá a los integrantes del mismo, una mejor comunicación y un mejor entendimiento que favorezcan el clima de trabajo y eviten así el desgaste emocional y de tiempo, que supone la confrontación de opiniones. Atendiendo a todo esto, es posible concluir que el trabajo en equipo no es más que el trabajo individual de diferentes profesionales y profesiones, que colaboran hacia un fin común o un mismo objetivo, que siempre será un beneficio, y aportará una atención global, puesto que reflejará todos los aspectos integrantes y representará la labor de todos los que lo integran (Fernández, 2022). \n        .col-5.d-none.d-xl-block\n          img(src='@/assets/curso/unidad/img-58.png', alt='Texto que describa la imagen')\n\n      #t_3_3.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.3\n          h2 Valorización de la diversidad en el trabajo en equipo\n\n      .row.mb-4\n        .col-10.col-lg-6.col-xl-4.bg-marron.p-4.d-flex(data-aos='fade-up')\n          span En el mundo laboral contemporáneo, la diversidad es una realidad ineludible. Los equipos suelen estar compuestos por personas de diferentes orígenes, culturas, habilidades y personalidades. Esta diversidad puede ser una poderosa ventaja competitiva si se maneja adecuadamente. Reconocer y valorar las diferencias entre los miembros del equipo, enriquece el proceso creativo y permite abordar problemas desde múltiples perspectivas.\n        .col-4.d-none.d-xl-block\n          img(src='@/assets/curso/unidad/img-59.png', alt='Texto que describa la imagen')\n        .col-10.col-lg-6.col-xl-4.bg-verde.p-4.d-flex(data-aos='fade-up')\n          span La inclusión de ideas y enfoques diversos, no solo mejora la toma de decisiones, sino que también impulsa la innovación. Los equipos que fomentan un ambiente inclusivo son más capaces de adaptarse a los cambios y encontrar soluciones efectivas a los desafíos que enfrentan. Además, la diversidad en el equipo, puede atraer diferentes talentos y habilidades, lo que a su vez mejora la capacidad del equipo para alcanzar sus objetivos.\n\n      #t_3_4.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.4\n          h2 Resiliencia: la clave para superar desafíos\n\n      p.mb-4 La resiliencia es una característica esencial en el trabajo en equipo, y su relevancia no puede subestimarse en un entorno laboral cada vez más dinámico y desafiante. Los contratiempos y desafíos son inevitables en cualquier proyecto, y un equipo resiliente es capaz de aprender de estas experiencias, adaptarse a nuevas situaciones y, en última instancia, salir fortalecido. La capacidad de recuperación no solo fortalece la cohesión del grupo, sino que también mejora la moral y fomenta un sentido de pertenencia entre los miembros. Ampliemos la información:\n\n      .row.position-relative.mb-5.py-4.bg-fondo-slider.bg-full-width\n        div.px-4.px-md-5.py-md-3\n          SlyderA(tipo=\"b\").bg-white\n            .row.p-4.px-md-5.py-lg-5.justify-content-between\n              .col-md-12.col-lg-7.mb-4.mb-md-0.d-flex.flex-column.justify-content-center\n                p.text-bold Primer tema \n                p Fomentar la resiliencia en un equipo, implica crear un ambiente propicio donde se valore el aprendizaje a partir de los errores y se celebren los logros, por pequeños que sean. Este proceso comienza con la promoción de una cultura de apertura y comunicación, donde todos los miembros se sientan seguros para expresar sus ideas y preocupaciones, sin temor a represalias. Este tipo de entorno no solo ayuda a identificar problemas antes de que se conviertan en crisis, sino que también permite que el equipo colabore de manera más efectiva, en la búsqueda de soluciones.\n              .d-none.d-lg-block.col-md-6.col-lg-5(data-aos=\"zoom-in\")\n                figure\n                  img(src='@/assets/curso/unidad/img-60.png', alt='Texto que describa la imagen') \n            .row.p-4.px-md-5.py-lg-5.justify-content-between\n              .col-md-12.col-lg-7.mb-4.mb-md-0.d-flex.flex-column.justify-content-center\n                p.text-bold Segundo tema\n                p Además, es fundamental que los líderes del equipo modelen la resiliencia, demostrando cómo enfrentar desafíos con una actitud positiva y una mentalidad orientada hacia el crecimiento. Al hacerlo, establecen un ejemplo a seguir y crean un estándar de comportamiento que inspira a los demás a adoptar una perspectiva similar. La resiliencia también se puede cultivar a través de la formación y el desarrollo de habilidades, como la gestión del estrés, la resolución de conflictos y la toma de decisiones bajo presión.\n              .d-none.d-lg-block.col-md-6.col-lg-5(data-aos=\"zoom-in\")\n                figure\n                  img(src='@/assets/curso/unidad/img-61.png', alt='Texto que describa la imagen') \n            .row.p-4.px-md-5.py-lg-5.justify-content-between\n              .col-md-12.col-lg-7.mb-4.mb-md-0.d-flex.flex-column.justify-content-center\n                p.text-bold Tercer tema\n                p Un equipo que apoya a sus miembros en momentos difíciles, es más capaz de enfrentar adversidades y seguir adelante. Este apoyo mutuo no solo se traduce en la recuperación de los contratiempos, sino que también construye relaciones más sólidas y un compromiso más profundo con los objetivos del grupo. Cuando los miembros del equipo saben que pueden contar unos con otros, se sienten más motivados para contribuir y colaborar, lo que resulta en un rendimiento general mejorado.\n              .d-none.d-lg-block.col-md-6.col-lg-5(data-aos=\"zoom-in\")\n                figure\n                  img(src='@/assets/curso/unidad/img-62.png', alt='Texto que describa la imagen') \n            .row.p-4.px-md-5.py-lg-5.justify-content-between\n              .col-md-12.col-lg-7.mb-4.mb-md-0.d-flex.flex-column.justify-content-center\n                p.text-bold Cuarto tema\n                p La resiliencia en el trabajo en equipo, no solo se refleja en la capacidad de superar obstáculos, sino también en la habilidad para innovar y adaptarse a los cambios. En un mundo en constante evolución, los equipos resilientes están mejor equipados para aprovechar nuevas oportunidades y enfrentar desafíos inesperados, lo que les permite mantenerse competitivos y relevantes. En resumen, invertir en la resiliencia del equipo no solo es una estrategia para superar desafíos, sino también un camino hacia el éxito sostenible a largo plazo.\n              .d-none.d-lg-block.col-md-6.col-lg-5(data-aos=\"zoom-in\")\n                figure\n                  img(src='@/assets/curso/unidad/img-63.png', alt='Texto que describa la imagen') \n\n      #t_3_5.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.5\n          h2 La gestión de conflictos como oportunidad de crecimiento\n\n      p.mb-4 Para conocer esta temática, lo invitamos a ver el siguiente video.\n\n      .row.bg-fondo-slider.bg-full-width.py-4.mb-4\n        div.px-5.pb-md-3\n          figure\n            .video\n              iframe(width='560' height='315' src='https://www.youtube.com' title='YouTube video player' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture' allowfullscreen)\n\n      #t_3_6.titulo-segundo(data-aos=\"flip-up\")\n        div.d-flex\n          span.me-3 3.6\n          h2 La autoeficacia y su impacto en el compromiso del equipo\n\n      .row.mb-4\n        .col-12.col-xl-10.mx-auto\n          .row\n            .col-12.bg-azul-oscuro.p-4.d-flex(data-aos=\"fade-up\")\n              p.mx-auto.text-bold La autoeficacia, o la confianza en las propias habilidades, es un motor fundamental en el trabajo en equipo.\n            .col-12.bg-azul.px-4.py-4.d-flex(data-aos=\"fade-up\")\n              .row\n                .col-12.col-xl-8.d-flex\n                  p.my-auto Cuando los miembros del equipo se sienten competentes y valorados, están más dispuestos a asumir responsabilidades y contribuir activamente al logro de los objetivos comunes.\n                .col-4.d-none.d-xl-block\n                  img(src='@/assets/curso/unidad/img-64.png', alt='Texto que describa la imagen')\n            .col-12.bg-azul-claro.px-4.py-4.d-flex(data-aos=\"fade-up\")\n              .row\n                .col-4.d-none.d-xl-block\n                  img(src='@/assets/curso/unidad/img-65.png', alt='Texto que describa la imagen')\n                .col-12.col-xl-8.d-flex\n                  p.my-auto La autoeficacia no solo impulsa la motivación individual, sino que también crea un efecto positivo en la dinámica del grupo, dado que los miembros se sienten inspirados por la confianza de sus compañeros.\n            .col-12.bg-azul-oscuro.p-4.d-flex(data-aos=\"fade-up\")\n              p.mx-auto.text-bold Fomentar la autoeficacia dentro del equipo, implica reconocer y celebrar los logros individuales y grupales.\n\n      .row.mb-4\n        .col-12.col-xl-8\n          p.mb-4 Proporcionar retroalimentación constructiva y oportunidades de desarrollo personal, ayuda a fortalecer la autoestima de los miembros. Un equipo donde cada persona se siente segura en sus capacidades, es más propenso a enfrentar desafíos y a alcanzar metas ambiciosas.\n          .d-flex.align-items-start.bg-verde.p-4(data-aos='fade-up').d-flex.align-items-center.flex-column.flex-md-row.mb-4\n            img.me-3(style='width: 90px' src='@/assets/curso/unidad/img-66.svg', alt='Texto descriptivo de la imagen')\n            .my-auto\n              p.pe-xl-3.mb-0 Las técnicas y habilidades personales y sociales, son esenciales para el trabajo positivo en equipo. La comunicación efectiva, la empatía, la valorización de la diversidad, la resiliencia, la gestión de conflictos y la autoeficacia son componentes interrelacionados que contribuyen a un entorno colaborativo positivo. Al invertir en el desarrollo de estas habilidades, las organizaciones no solo mejoran la dinámica de sus equipos, sino que también potencian su capacidad para innovar, adaptarse y prosperar en un entorno laboral en constante cambio. En definitiva, promover un desarrollo integral de las habilidades personales y sociales de los miembros del equipo, es un paso crucial hacia el éxito organizacional.\n\n        .col-4.d-none.d-xl-block\n          img(src='@/assets/curso/unidad/img-67.png', alt='Texto que describa la imagen')\n\n      .bg-full-width.border-top.actividad.mb-5(style='background-color: #ebf1f5; border-top: 5px solid #f5c145 !important')\n        .p-4.p-md-5\n          #Actividad\n            <Actividad :cuestionario='cuestionario'/>\n\n\n      .bg-full-width.border-top-9-azul\n        .px-5.pt-5.pb-0\n          h2 Material complementario\n          .row\n            .col-12.col-md-6.col-lg-8\n              p.d-flex.my-4\n                img.me-3.mb-auto.mt-1(src='@/assets/componentes/book.svg' :style=\"{'max-width':'16px'}\")\n                a.text-small.text-primary(target=\"_blank\", href=\"https://elibro.net/es/lc/tecnologicadeloriente/titulos/228831\") Reza Trosino, J. C. (2019). El gerente efectivo: los fundamentos de la administración, el trabajo en equipo y el liderazgo. (1 ed.). Universidad Nacional Autónoma de México (UNAM).\n              \n              p.d-flex.my-4\n                img.me-3.mb-auto.mt-1(src='@/assets/componentes/podcast-icon.svg' :style=\"{'max-width':'16px'}\")\n                a.text-small.text-primary(target=\"_blank\", href=\"https://open.spotify.com/episode/1oXFnKBbuxhuPdRaWwCTNE?si=83kRdUVPSnW_MeCVOd6uqw\") [Podcast] Soria, A. (2024, 13 de julio). Comunicación asertiva y resolución de conflictos.\n            \n            .col-12.col-md-6.col-lg-3\n              figure\n                img(src='@/assets/componentes/material-complementario.svg' alt='Imagen de material complementario')\n\n\n\n</template>\n\n<script>\nimport Actividad from '@/components/actividad/Actividad.vue'\nexport default {\n  name: 'Tema3',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Liderazgo y Trabajo en Equipo',\n      titulo: 'Ponte a prueba',\n      introduccion:\n        'Demuestra lo que aprendiste en esta unidad y pon a prueba tus conocimientos.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Cuál es una característica clave del liderazgo según el texto?',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Tener un título formal', esCorrecta: false },\n            {\n              id: 'b',\n              texto: 'Influenciar e inspirar a otros',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Tomar decisiones unilateralmente',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Mantener una jerarquía estricta',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto:\n            'El texto enfatiza que el liderazgo implica la capacidad de influir e inspirar a otros, no solo ocupar una posición jerárquica.',\n        },\n        {\n          id: 2,\n          texto: 'La gestión de conflictos en un equipo debe ser vista como:',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Un signo de debilidad', esCorrecta: false },\n            {\n              id: 'b',\n              texto: 'Una oportunidad de crecimiento',\n              esCorrecta: true,\n            },\n            { id: 'c', texto: 'Un problema a evitar', esCorrecta: false },\n            {\n              id: 'd',\n              texto: 'Una tarea exclusiva del líder',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto:\n            'Los conflictos pueden ser catalizadores para la innovación y el crecimiento si se manejan adecuadamente.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n  mounted() {\n    this.$nextTick(() => {\n      this.$aosRefresh()\n    })\n  },\n}\n</script>\n\n<style lang=\"sass\">\n.bg-color-actividad\n  background-color: #EBF1F5\n</style>\n"],"sourceRoot":"src/views/curso"}]}